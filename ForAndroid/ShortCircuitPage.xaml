<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ForAndroid.ShortCircuitPage"
             Title="Расчёт тока КЗ"
             BackgroundColor="#121212">

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="15">

            <Label Text="Расчёт тока КЗ из сопротивления нагрузки"
                   TextColor="#FF5252"
                   FontAttributes="Italic,Bold"
                   FontSize="18"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,10"/>

            <Label Text="Напряжение без нагрузки:" TextColor="White" FontAttributes="Bold"/>
            <Entry x:Name="EntryU0" Keyboard="Numeric" BackgroundColor="#2D2D2D" TextColor="White" Placeholder="Введите U0" PlaceholderColor="#B0B0B0"/>

            <Label Text="Напряжение под нагрузкой:" TextColor="White" FontAttributes="Bold"/>
            <Entry x:Name="EntryU" Keyboard="Numeric" BackgroundColor="#2D2D2D" TextColor="White" Placeholder="Введите U1" PlaceholderColor="#B0B0B0"/>

            <Label Text="Сопротивление нагрузки:" TextColor="White" FontAttributes="Bold"/>
            <Entry x:Name="EntryR" Keyboard="Numeric" BackgroundColor="#2D2D2D" TextColor="White" Placeholder="Введите R" PlaceholderColor="#B0B0B0"/>

            <Label Text="Результат:" TextColor="White" FontAttributes="Bold"/>
            <Entry x:Name="EntryResult" IsReadOnly="True" BackgroundColor="#1E1E1E" TextColor="#64B5F6" Margin="0,0,0,10"/>

            <Button Text="Рассчитать" 
                    BackgroundColor="#333333" TextColor="White"
                    Clicked="OnCalculateClicked"/>

            <Button Text="Назад" 
                    BackgroundColor="#B71C1C" TextColor="White"
                    Clicked="OnBackClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>