<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ForAndroid.WireCalculatorPage"
             Title="Расчет сечения"
             BackgroundColor="#121212">

    <ScrollView>
        <VerticalStackLayout Spacing="10" Padding="15">

            <Label Text="Расчёт из диаметра в сечение – мм в мм²"
                   TextColor="#FF5252"
                   FontAttributes="Italic,Bold"
                   FontSize="16"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,10"/>

            <Label Text="Диаметр (мм):" TextColor="White" FontAttributes="Bold"/>
            <Entry x:Name="EntryDiameter" Keyboard="Numeric" BackgroundColor="#2D2D2D" TextColor="White" Placeholder="Введите диаметр" PlaceholderColor="#B0B0B0"/>

            <Button Text="Рассчитать" 
                    BackgroundColor="#333333" TextColor="White"
                    Clicked="OnCalculateWireClicked"/>

            <Label Text="Сечение (мм²):" TextColor="White" FontAttributes="Bold"/>
            <Entry x:Name="EntryWireResult" IsReadOnly="True" BackgroundColor="#1E1E1E" TextColor="#64B5F6" Margin="0,0,0,20"/>

            <Button Text="Назад" 
                    BackgroundColor="#B71C1C" TextColor="White"
                    Clicked="OnBackClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>