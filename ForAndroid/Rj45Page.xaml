<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ForAndroid.Rj45Page"
             Title="Распиновка RJ-45"
             BackgroundColor="#121212">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="15">
            <Label Text="Слаботочная электрика"
                   TextColor="#FF5252"
                   FontAttributes="Bold"
                   FontSize="20"
                   HorizontalTextAlignment="Center"/>

            <Label Text="Распиновка RJ-45"
                   TextColor="#64B5F6"
                   FontAttributes="Italic,Bold"
                   FontSize="16"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,5"/>

            <!-- Картинка схемы (положи rj45_pinout.png в Resources/Images) -->
            <Image Source="rj45_pinout.png"
                   Aspect="AspectFit"
                   BackgroundColor="White"
                   HeightRequest="380"
                   Margin="0,5"/>

            <Button Text="Назад" 
                    BackgroundColor="#B71C1C" 
                    TextColor="White" 
                    Clicked="OnBackClicked"
                    Margin="0,10,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>